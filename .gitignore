# .claude/: ignore local skill/plugin installs and personal overrides, but keep
# the shared, checked-in agent infra (SessionStart bootstrap, permission
# allowlist, slash commands). See .claude/README.md.
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/commands/
!.claude/README.md
.claude/settings.local.json
.claude/.session-env
