# Supabase local dev (values printed by `supabase start`).
# Leave BOTH unset to use the dev emulator (dev/supabase-dev-server.ts):
# supabase-js then talks to the Vite dev server itself, backed by local
# Postgres with real RLS. Dev login: any provisioned email + password 'demo'.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Server-side scripts (migrate, seed, tests). Defaults to Supabase local db.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
