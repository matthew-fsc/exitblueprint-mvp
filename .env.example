# Local dev + CI. Leave the Supabase + Clerk vars UNSET to use the dev emulator
# (dev/supabase-dev-server.ts): supabase-js talks to the Vite dev server itself,
# backed by local Postgres with real RLS. Dev login: any provisioned email +
# password 'demo'. This is the only non-Clerk path — hosted Supabase-Auth login
# was removed when Clerk became the standard identity provider (docs/30).
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Server-side scripts (migrate, seed, tests). Defaults to Supabase local db.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres


# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION (see docs/11-deploy-runbook.md). Never commit real secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database stand-up (npm run db:setup) ────────────────────────────────────
# For MIGRATIONS, DATABASE_URL must be a SESSION-mode string: the direct
# connection (db.<ref>.supabase.co:5432, IPv6) or the Session pooler
# (aws-0-<region>.pooler.supabase.com:5432, IPv4). NOT the Transaction pooler
# (:6543) — it can't run migrations. Percent-encode special chars in the password.
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.<ref>.supabase.co:5432/postgres

# ─── Compute service (server/http.ts, npm run serve:functions) ───────────────
# DATABASE_URL             service-role Postgres string (a pooler string is fine)
# FUNCTIONS_JWT_SECRET     verifies Supabase access tokens. LEGACY projects: the
#                          project JWT secret (Settings → API → JWT Secret). NEW
#                          projects using asymmetric JWT signing keys need JWKS
#                          verification instead — see the runbook.
# SUPABASE_URL             https://<ref>.supabase.co — verifies asymmetric tokens
#                          via project JWKS, and is reused by the owner-invite email
# CLERK_JWKS_URL           REQUIRED in prod. Clerk JWKS — verifies session tokens
#                          (https://<clerk-domain>/.well-known/jwks.json). For
#                          exitblueprint.net: https://clerk.exitblueprint.net/.well-known/jwks.json
# CLERK_SECRET_KEY         Clerk backend key (sk_...). Enables Clerk organization
#                          invitations for owners (server/invite.ts) AND automatic
#                          firm/advisor provisioning (scripts/admin.ts). Omit for
#                          local/CI to stay on the dev path.
# CLERK_API_URL            optional; Clerk Backend API base (default https://api.clerk.com/v1)
# CLERK_WEBHOOK_SIGNING_SECRET  Svix signing secret (whsec_...) from the Clerk
#                          dashboard webhook. Enables POST /webhooks/clerk, which
#                          auto-provisions firms/advisors/owners on Clerk events
#                          (docs/30 §5). Unset → the endpoint replies 503.
# FUNCTIONS_ALLOWED_ORIGIN your deployed frontend origin (CORS); default *
# EB_DOCUMENT_KEY          32-byte hex — REQUIRED in prod (encrypts uploaded docs);
#                          gen: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OWNER_INVITE_REDIRECT_URL  optional; where the Clerk invite link lands
#                          (defaults to FUNCTIONS_ALLOWED_ORIGIN)
# PORT                     default 8787
# ANTHROPIC_API_KEY        optional; enables real Claude narrative (else the
#                          deterministic rule-based composer is used)

# ─── Admin provisioning (npm run admin, scripts/admin.ts) ────────────────────
# DATABASE_URL             the project's service-role Postgres string
# CLERK_SECRET_KEY         set → create-firm provisions the Clerk Organization and
#                          create-advisor provisions the Clerk user + membership.
#                          Unset → the dev path (auth.users) for local seeding.

# ─── Frontend production build ───────────────────────────────────────────────
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY  point at the real project (REST/RLS)
# VITE_FUNCTIONS_URL       base URL of the deployed compute service. Unset =
#                          same-origin (the dev emulator); set it in production.
# VITE_CLERK_PUBLISHABLE_KEY  REQUIRED in prod (pk_...). Clerk is the identity
#                          provider — login/MFA/invites via Clerk (docs/30). Unset
#                          is supported ONLY for the local dev emulator (local/CI);
#                          a hosted deploy without it shows a "not configured" page.
