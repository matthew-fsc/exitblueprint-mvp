# Local dev + CI. Leave the Supabase + Clerk vars UNSET to use the dev emulator
# (dev/supabase-dev-server.ts): supabase-js talks to the Vite dev server itself,
# backed by local Postgres with real RLS. Dev login: any provisioned email +
# password 'demo'. This is the only non-Clerk path — hosted Supabase-Auth login
# was removed when Clerk became the standard identity provider (docs/30).
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Server-side scripts (migrate, seed, tests). Defaults to Supabase local db.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres


# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION (see docs/archive/11-deploy-runbook.md). Never commit real secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database stand-up (npm run db:setup) ────────────────────────────────────
# For MIGRATIONS, DATABASE_URL must be a SESSION-mode string: the direct
# connection (db.<ref>.supabase.co:5432, IPv6) or the Session pooler
# (aws-0-<region>.pooler.supabase.com:5432, IPv4). NOT the Transaction pooler
# (:6543) — it can't run migrations. Percent-encode special chars in the password.
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.<ref>.supabase.co:5432/postgres

# ─── Compute service (server/http.ts, npm run serve:functions) ───────────────
# DATABASE_URL             service-role Postgres string. Use the Supabase IPv4
#                          session pooler (postgres.<ref>@aws-0-<region>.pooler.
#                          supabase.com:5432) — NOT the IPv6 direct connection
#                          (Render can't route IPv6 → connect ENETUNREACH). An
#                          in-string sslmode=require is fine (TLS is handled below).
# DATABASE_CA_CERT         optional PEM of the Supabase CA cert (dashboard →
#                          Database → SSL configuration). Set it to verify the DB
#                          server certificate (verify-full). Unset → the connection
#                          is still TLS-encrypted but the cert isn't verified.
# FUNCTIONS_JWT_SECRET     verifies Supabase access tokens. LEGACY projects: the
#                          project JWT secret (Settings → API → JWT Secret). NEW
#                          projects using asymmetric JWT signing keys need JWKS
#                          verification instead — see the runbook.
# SUPABASE_URL             https://<ref>.supabase.co — verifies asymmetric tokens
#                          via project JWKS, and is reused by the owner-invite email
# CLERK_JWKS_URL           REQUIRED in prod. Clerk JWKS — verifies session tokens
#                          (https://<clerk-domain>/.well-known/jwks.json). For
#                          exitblueprint.net: https://clerk.exitblueprint.net/.well-known/jwks.json
# CLERK_SECRET_KEY         Clerk backend key (sk_...). Enables Clerk organization
#                          invitations for owners (server/invite.ts) AND automatic
#                          firm/advisor provisioning (scripts/admin.ts). Omit for
#                          local/CI to stay on the dev path.
# CLERK_API_URL            optional; Clerk Backend API base (default https://api.clerk.com/v1)
# CLERK_WEBHOOK_SIGNING_SECRET  Svix signing secret (whsec_...) from the Clerk
#                          dashboard webhook. Enables POST /webhooks/clerk, which
#                          auto-provisions firms/advisors/owners on Clerk events
#                          (docs/30 §5). Unset → the endpoint replies 503.
# FUNCTIONS_ALLOWED_ORIGIN your deployed frontend origin(s) for CORS; default *.
#                          Comma-separate to allow more than one (e.g. apex + www:
#                          https://exitblueprint.net,https://www.exitblueprint.net)
#                          — the caller's matching Origin is echoed back per request.
# EB_DOCUMENT_KEY          32-byte hex — REQUIRED in prod (encrypts uploaded docs);
#                          gen: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OWNER_INVITE_REDIRECT_URL  optional; where the Clerk invite link lands
#                          (defaults to FUNCTIONS_ALLOWED_ORIGIN)
# PORT                     default 8787
# AI_GATEWAY_API_KEY       optional; enables real Claude narrative. All AI runs
#                          through the Vercel AI Gateway (Anthropic-compatible
#                          Messages API) — we reach Anthropic through Vercel, so
#                          there is no separate Anthropic key. Unset → the
#                          deterministic rule-based composer is used. If the
#                          gateway balance is empty the call fails and the service
#                          falls back to that same composer — reports still
#                          generate, just rule-based (top up the balance to restore
#                          AI narrative). Get it from Vercel → AI Gateway → API keys.
# ─── Billing (Stripe, docs/24) ───────────────────────────────────────────────
# STRIPE_SECRET_KEY        sk_... — enables checkout + billing-portal sessions and
#                          the /webhooks/stripe handler. Unset → billing endpoints
#                          reply 503 (disabled); the app runs comped.
# STRIPE_WEBHOOK_SECRET    whsec_... from the Stripe dashboard webhook. Point it at
#                          https://<compute-host>/webhooks/stripe. Signature-verified
#                          on the raw body; unset → the webhook replies 503.
# BILLING_ENFORCED         'true' turns the server-side entitlement gate ON (gated
#                          functions require an active/trialing/comped firm). Unset/
#                          any other value → gate OFF (beta). Comped firms always pass.
# ─── Continuous-evaluation webhooks (n8n, docs/07) ───────────────────────────
# WEBHOOK_SECRET           shared secret for POST /webhooks/scheduled/* (stale-
#                          engagements, stalled-tasks, reassessment-due). n8n sends
#                          it as the x-webhook-secret header. Unset → those endpoints
#                          reply 503 (disabled).
# WEBHOOK_RATE_LIMIT       max requests per client IP per window for the two
#                          unauthenticated webhook routes (/webhooks/clerk and
#                          /webhooks/scheduled/*); default 60. Over the limit → 429
#                          with a Retry-After header.
# WEBHOOK_RATE_WINDOW_SEC  rate-limit window length in seconds; default 60.
# API_RATE_LIMIT           max requests per client IP per window for the
#                          authenticated function surface (/functions/v1/*),
#                          checked before token verification; default 300. Over
#                          the limit → 429 with a Retry-After header. Raise it for
#                          a NAT'd firm where many advisors share one egress IP.
# API_RATE_WINDOW_SEC      rate-limit window length in seconds for the above; default 60.
# ─── Observability (Sentry, docs/32) ─────────────────────────────────────────
# SENTRY_DSN               server error monitoring. Unset → disabled (no SDK active).
# SENTRY_ENVIRONMENT       optional label (e.g. production) attached to events.
# SENTRY_TRACES_SAMPLE_RATE  optional 0..1 performance sampling; default 0 (errors only).
# ─── Platform administration ─────────────────────────────────────────────────
# PLATFORM_SUPERADMIN_IDS  comma-separated Clerk user ids allowed to load methodology
#                          from inside the system (the superadmin-gated `seed-methodology`
#                          function — "Load methodology" on /health). Unset → 403.

# ─── Admin provisioning (npm run admin, scripts/admin.ts) ────────────────────
# DATABASE_URL             the project's service-role Postgres string
# CLERK_SECRET_KEY         set → create-firm provisions the Clerk Organization and
#                          create-advisor provisions the Clerk user + membership.
#                          Unset → the dev path (auth.users) for local seeding.

# ─── Frontend production build ───────────────────────────────────────────────
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY  point at the real project (REST/RLS)
# VITE_FUNCTIONS_URL       base URL of the deployed compute service. Unset =
#                          same-origin (the dev emulator); set it in production.
# VITE_CLERK_PUBLISHABLE_KEY  REQUIRED in prod (pk_...). Clerk is the identity
#                          provider — login/MFA/invites via Clerk (docs/30). Unset
#                          is supported ONLY for the local dev emulator (local/CI);
#                          a hosted deploy without it shows a "not configured" page.
# VITE_SENTRY_DSN          optional; frontend error monitoring. Build-time var on
#                          Vercel. Unset → the Sentry SDK is never loaded (docs/32).
