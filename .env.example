# Supabase local dev (values printed by `supabase start`).
# Leave BOTH unset to use the dev emulator (dev/supabase-dev-server.ts):
# supabase-js then talks to the Vite dev server itself, backed by local
# Postgres with real RLS. Dev login: any provisioned email + password 'demo'.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Server-side scripts (migrate, seed, tests). Defaults to Supabase local db.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres


# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION (see docs/11-deploy-runbook.md). Never commit real secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database stand-up (npm run db:setup) ────────────────────────────────────
# For MIGRATIONS, DATABASE_URL must be a SESSION-mode string: the direct
# connection (db.<ref>.supabase.co:5432, IPv6) or the Session pooler
# (aws-0-<region>.pooler.supabase.com:5432, IPv4). NOT the Transaction pooler
# (:6543) — it can't run migrations. Percent-encode special chars in the password.
#   DATABASE_URL=postgresql://postgres:[PASSWORD]@db.<ref>.supabase.co:5432/postgres

# ─── Compute service (server/http.ts, npm run serve:functions) ───────────────
# DATABASE_URL             service-role Postgres string (a pooler string is fine)
# FUNCTIONS_JWT_SECRET     verifies Supabase access tokens. LEGACY projects: the
#                          project JWT secret (Settings → API → JWT Secret). NEW
#                          projects using asymmetric JWT signing keys need JWKS
#                          verification instead — see the runbook.
# SUPABASE_URL             https://<ref>.supabase.co — verifies asymmetric tokens
#                          via project JWKS, and is reused by the owner-invite email
# CLERK_JWKS_URL           Clerk JWKS (https://<clerk-domain>/.well-known/jwks.json)
#                          — set when auth is Clerk; wins over the Supabase JWKS (docs/30)
# CLERK_SECRET_KEY         Clerk backend key — enables Clerk organization invitations
#                          for owners (server/invite.ts). Omit outside the Clerk stack.
# FUNCTIONS_ALLOWED_ORIGIN your deployed frontend origin (CORS); default *
# EB_DOCUMENT_KEY          32-byte hex — REQUIRED in prod (encrypts uploaded docs);
#                          gen: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SUPABASE_SERVICE_ROLE_KEY  service_role key — enables real owner-invite emails
#                          (Supabase Auth admin). Omit to fall back to the dev path.
# OWNER_INVITE_REDIRECT_URL  optional; where the invite set-password link lands
#                          (defaults to FUNCTIONS_ALLOWED_ORIGIN)
# PORT                     default 8787
# ANTHROPIC_API_KEY        optional; enables real Claude narrative (else the
#                          deterministic rule-based composer is used)

# ─── Frontend production build ───────────────────────────────────────────────
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY  point at the real project (REST; auth
#                          too when NOT on Clerk)
# VITE_FUNCTIONS_URL       base URL of the deployed compute service. Unset =
#                          same-origin (the dev emulator); set it in production.
# VITE_CLERK_PUBLISHABLE_KEY  Clerk publishable key. SET = Clerk is the identity
#                          provider (login/MFA/invites via Clerk; docs/30). UNSET =
#                          the Supabase-Auth / dev path, unchanged.
